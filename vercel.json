{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/docs/swagger-ui-bundle.js",
      "headers": { "Location": "https://cdn.jsdelivr.net/npm/swagger-ui-dist@5.32.6/swagger-ui-bundle.js" },
      "status": 302
    },
    {
      "src": "/api/docs/swagger-ui-standalone-preset.js",
      "headers": { "Location": "https://cdn.jsdelivr.net/npm/swagger-ui-dist@5.32.6/swagger-ui-standalone-preset.js" },
      "status": 302
    },
    {
      "src": "/api/docs/swagger-ui.css",
      "headers": { "Location": "https://cdn.jsdelivr.net/npm/swagger-ui-dist@5.32.6/swagger-ui.css" },
      "status": 302
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
